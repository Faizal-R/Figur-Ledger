# Auth Service Configuration
PORT=5001
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://user:password@localhost:27017/auth_db?authSource=admin

# RabbitMQ
RABBITMQ_URI=amqp://user:password@localhost:5672

# Redis (Optional/Future fallback)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Secrets
ACCESS_TOKEN_SECRET=your-secret-access-key
REFRESH_TOKEN_SECRET=your-secret-refresh-key

# JWT Expiry
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
VERIFICATION_TOKEN_EXPIRY=1h

# Cookie Configuration
REFRESH_COOKIE_DAYS=7

# CORS / Origins
FRONTEND_DOMAIN_URL=http://localhost:3000
